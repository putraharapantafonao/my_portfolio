{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "@vercel/php"
        }
    },
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/public/assets/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
